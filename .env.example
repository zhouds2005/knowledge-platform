# ===========================================
# 部门文件共享平台 — 环境变量
# 复制此文件为 .env 并修改实际值
# ===========================================

# ---- 数据库 ----
# PostgreSQL 连接字符串
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_platform

# ---- 认证 ----
# 用于签名 session cookie，部署时必须改为强随机值
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=change-me-to-a-random-64-char-string

# ---- Nextcloud 集成 ----
# 填写实际 Nextcloud 实例地址和管理员凭据
NEXTCLOUD_URL=https://nextcloud.example.com
NEXTCLOUD_USER=admin
NEXTCLOUD_PASS=password

# ---- MaxKey OIDC ----
MAXKEY_ISSUER=https://maxkey.example.com
MAXKEY_CLIENT_ID=knowledge-platform
MAXKEY_CLIENT_SECRET=change-me
MAXKEY_REDIRECT_URI=http://localhost:3002/api/auth/callback

# ---- 服务端口 ----
# API 服务监听端口（默认 3002），前端由 Vite/nginx 代理
PORT=3002
